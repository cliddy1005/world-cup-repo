# Do not put your real token in public/index.html.
# Put it here locally or configure it as a secret in your hosting platform.
FOOTBALL_DATA_TOKEN=replace_with_your_football_data_token
FOOTBALL_DATA_COMPETITION=WC
FOOTBALL_DATA_SEASON=2026
FIREBASE_DATABASE_URL=https://wc-pool-2026-default-rtdb.europe-west1.firebasedatabase.app

# Use Google Application Default Credentials locally:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/firebase-service-account.json

# Optional idle polling interval when no games are live. Use 0 to disable auto-sync.
AUTO_SYNC_SECONDS=0

# Optional live polling interval. Minimum enforced value is 10 seconds.
LIVE_SYNC_SECONDS=10

# Optional rolling request budget across manual + auto syncs.
MAX_SYNC_CALLS_PER_MINUTE=10
PORT=3000
